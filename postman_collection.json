{
  "info": {
    "name": "Simple Bank API (Flask + MongoDB)",
    "_postman_id": "banking-app-flask-mongo-v1",
    "description": "All endpoints for the Simple Banking Application.\nBackend: Python Flask on port 5000.\nDatabase: MongoDB (ObjectId strings as IDs).\n\nIMPORTANT: After calling 'Create Account', copy the returned account_id (24-char hex) into the 'account_id' collection variable before calling other endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",   "value": "http://localhost:5000" },
    { "key": "account_id", "value": "PASTE_ACCOUNT_ID_HERE" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      }
    },
    {
      "name": "Create Account",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/accounts/", "host": ["{{base_url}}"], "path": ["api","accounts",""] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"account_type\": \"SAVINGS\"\n}"
        }
      }
    },
    {
      "name": "Get Account Details",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/accounts/{{account_id}}",
          "host": ["{{base_url}}"], "path": ["api","accounts","{{account_id}}"]
        }
      }
    },
    {
      "name": "Deposit Money",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{base_url}}/api/accounts/{{account_id}}/deposit",
          "host": ["{{base_url}}"], "path": ["api","accounts","{{account_id}}","deposit"]
        },
        "body": { "mode": "raw", "raw": "{\n  \"amount\": 500\n}" }
      }
    },
    {
      "name": "Withdraw Money",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{base_url}}/api/accounts/{{account_id}}/withdraw",
          "host": ["{{base_url}}"], "path": ["api","accounts","{{account_id}}","withdraw"]
        },
        "body": { "mode": "raw", "raw": "{\n  \"amount\": 200\n}" }
      }
    },
    {
      "name": "Transaction History",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/accounts/{{account_id}}/transactions",
          "host": ["{{base_url}}"], "path": ["api","accounts","{{account_id}}","transactions"]
        }
      }
    }
  ]
}
